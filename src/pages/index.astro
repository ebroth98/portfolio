---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.js';
import { samples } from '../data/samples.js';

const featured = samples.filter(s => s.featured);
const { home, stats } = SITE;
---

<BaseLayout title={SITE.siteTitle} description={SITE.description}>

  <section class="home-hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">

      <!-- Left: headshot + name + bio + stats + buttons -->
      <div class="hero-left">
        <div class="portrait-wrap fade-up">
          <img src="/headshot.jpg" alt={SITE.name} class="portrait" />
          <div class="portrait-offset"></div>
        </div>
        <div class="hero-identity">
          <p class="eyebrow fade-up delay-1">{home.eyebrow}</p>
          <h1 class="fade-up delay-1">{SITE.name}</h1>
          <div class="rule fade-up delay-2"></div>
          <p class="hero-bio fade-up delay-2">{home.bio}</p>
          <div class="stat-row fade-up delay-3">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-num">{s.num}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
          <div class="hero-actions fade-up delay-4">
            <a href="/work"    class="btn btn-primary">{home.cta_primary}</a>
            <a href="/contact" class="btn btn-outline">{home.cta_secondary}</a>
          </div>
        </div>
      </div>

      <!-- Right: featured writing sample cards stacked -->
      <div class="hero-right fade-up delay-2">
        <div class="cards-header">
          <p class="eyebrow">{home.featured_heading}</p>
          <a href="/work" class="view-all">{home.featured_link}</a>
        </div>
        <div class="samples-stack">
          {featured.map((sample) => (
            <article class="sample-card">
              <div class="card-top">
                <span class={sample.tagClass}>{sample.category}</span>
                <span class="read-time">{sample.readTime}</span>
              </div>
              <h3 class="card-title">{sample.title}</h3>
              <p class="card-desc">{sample.description}</p>
              <blockquote class="card-quote">{sample.excerpt}</blockquote>
              <div class="card-skills">
                {sample.skills.map((sk) => (
                  <span class="skill">{sk}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-block: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 65% at 75% 40%, rgba(26,68,89,0.2) 0%, transparent 65%),
      linear-gradient(180deg, var(--void) 0%, var(--obsidian) 100%);
  }

  /* Two column layout */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  /* Left column */
  .hero-left { display: flex; flex-direction: column; gap: 1.5rem; }

  .portrait-wrap { position: relative; width: clamp(160px, 18vw, 240px); flex-shrink: 0; }
  .portrait { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; position: relative; z-index: 1; }
  .portrait-offset {
    position: absolute; bottom: -8px; right: -8px;
    width: 100%; height: 100%; border: 1px solid var(--glacier); opacity: 0.35; z-index: 0;
  }

  .hero-identity h1 { font-size: clamp(1.8rem, 3vw, 3rem); letter-spacing: -0.025em; margin-bottom: 0; }
  .hero-bio { font-size: 0.95rem; font-weight: 300; color: var(--silver); line-height: 1.85; margin-bottom: 1.25rem; max-width: 44ch; }

  .stat-row { display: flex; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-num { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 400; color: var(--ice); line-height: 1; letter-spacing: -0.02em; }
  .stat-label { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* Right column */
  .hero-right { display: flex; flex-direction: column; gap: 1rem; }

  .cards-header {
    display: flex; align-items: center;
    justify-content: space-between; margin-bottom: 0.25rem;
  }
  .cards-header .eyebrow { margin-bottom: 0; }
  .view-all { font-size: 0.75rem; font-weight: 500; color: var(--frost); transition: color 0.2s; white-space: nowrap; }
  .view-all:hover { color: var(--ice); }

  .samples-stack { display: flex; flex-direction: column; gap: 1rem; }

  .sample-card {
    background: var(--obsidian); border: 1px solid var(--ghost);
    padding: 1.25rem; display: flex; flex-direction: column; gap: 0.6rem;
    transition: border-color 0.25s, transform 0.25s;
  }
  .sample-card:hover { border-color: var(--dim); transform: translateX(3px); }
  .card-top { display: flex; justify-content: space-between; align-items: center; }
  .read-time { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.08em; color: var(--dim); }
  .card-title { font-size: 1rem; letter-spacing: -0.01em; line-height: 1.2; }
  .card-desc { font-size: 0.82rem; color: var(--silver); line-height: 1.65; max-width: none; }
  .card-quote { border-left: 2px solid var(--glacier); padding-left: 0.85rem; font-style: italic; font-size: 0.82rem; color: var(--ice); opacity: 0.75; line-height: 1.6; max-width: none; }
  .card-skills { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .skill { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.06em; padding: 0.18rem 0.5rem; border: 1px solid var(--ghost); color: var(--dim); }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .portrait-wrap { width: min(180px, 45vw); }
    .hero-identity h1 { font-size: clamp(2rem, 6vw, 3.5rem); }
  }
</style>

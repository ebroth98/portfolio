---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.js';
import { samples } from '../data/samples.js';

const featured = samples.filter(s => s.featured);
const { home, stats } = SITE;
---

<BaseLayout title={SITE.siteTitle} description={SITE.description}>

  <section class="home-hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">

      <div class="portrait-wrap fade-up">
        <!-- Replace this div with: <img src="/headshot.jpg" alt={SITE.name} class="portrait" /> -->
        <img src="/headshot.jpg" alt={SITE.name} class="portrait" />
          <span class="portrait-initials">YN</span>
          <p class="portrait-hint">Add your headshot here</p>
        </div>
        <div class="portrait-offset"></div>
      </div>

      <div class="hero-identity">
        <p class="eyebrow fade-up delay-1">{home.eyebrow}</p>
        <h1 class="fade-up delay-1">{SITE.name}</h1>
        <div class="rule fade-up delay-2"></div>
        <p class="hero-bio fade-up delay-2">{home.bio}</p>

        <div class="stat-row fade-up delay-3">
          {stats.map((s) => (
            <div class="stat">
              <span class="stat-num">{s.num}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>

        <div class="hero-actions fade-up delay-4">
          <a href="/work"    class="btn btn-primary">{home.cta_primary}</a>
          <a href="/contact" class="btn btn-outline">{home.cta_secondary}</a>
        </div>
      </div>

    </div>
  </section>

  <section class="featured-section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">{home.featured_heading}</p>
          <h2>{home.featured_subhead}</h2>
        </div>
        <a href="/work" class="view-all">{home.featured_link}</a>
      </div>

      <div class="samples-grid">
        {featured.map((sample) => (
          <article class="sample-card">
            <div class="card-top">
              <span class={sample.tagClass}>{sample.category}</span>
              <span class="read-time">{sample.readTime}</span>
            </div>
            <h3 class="card-title">{sample.title}</h3>
            <p class="card-desc">{sample.description}</p>
            <blockquote class="card-quote">{sample.excerpt}</blockquote>
            <div class="card-skills">
              {sample.skills.map((sk) => (
                <span class="skill">{sk}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .home-hero {
    position: relative; min-height: 88vh;
    display: flex; align-items: center;
    padding-block: clamp(5rem, 10vw, 8rem); overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 65% at 75% 40%, rgba(26,68,89,0.2) 0%, transparent 65%),
      linear-gradient(180deg, var(--void) 0%, var(--obsidian) 100%);
  }
  .hero-inner {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(3rem, 6vw, 7rem); align-items: center; position: relative; z-index: 1;
  }

  .portrait-wrap { position: relative; width: clamp(200px, 22vw, 300px); flex-shrink: 0; }
  .portrait { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; position: relative; z-index: 1; }
  .portrait-placeholder {
    width: 100%; aspect-ratio: 3/4; background: var(--steel); border: 1px solid var(--ghost);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; position: relative; z-index: 1;
  }
  .portrait-initials { font-family: var(--font-heading); font-size: 3rem; font-weight: 300; color: var(--dim); }
  .portrait-hint { font-size: 0.65rem; color: var(--dim); text-align: center; max-width: 14ch; line-height: 1.4; }
  .portrait-offset {
    position: absolute; bottom: -10px; right: -10px;
    width: 100%; height: 100%; border: 1px solid var(--glacier); opacity: 0.35; z-index: 0;
  }

  .hero-identity h1 { font-size: clamp(2.8rem, 5vw, 5rem); letter-spacing: -0.025em; }
  .hero-bio { font-size: clamp(0.95rem, 1.2vw, 1.05rem); font-weight: 300; color: var(--silver); line-height: 1.85; margin-bottom: 2rem; max-width: 50ch; }

  .stat-row { display: flex; gap: 2.5rem; margin-bottom: 2.25rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-num { font-family: var(--font-heading); font-size: 2rem; font-weight: 400; color: var(--ice); line-height: 1; letter-spacing: -0.02em; }
  .stat-label { font-size: 0.65rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .featured-section { background: var(--deep); border-top: 1px solid var(--ghost); padding-block: clamp(4rem, 8vw, 7rem); }
  .section-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
  .section-head h2 { margin: 0; }
  .view-all { font-size: 0.78rem; font-weight: 500; color: var(--frost); letter-spacing: 0.04em; transition: color 0.2s; white-space: nowrap; }
  .view-all:hover { color: var(--ice); }

  .samples-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .sample-card {
    background: var(--obsidian); border: 1px solid var(--ghost);
    padding: 1.75rem; display: flex; flex-direction: column; gap: 0.9rem;
    transition: border-color 0.25s, transform 0.25s;
  }
  .sample-card:hover { border-color: var(--dim); transform: translateY(-3px); }
  .card-top { display: flex; justify-content: space-between; align-items: center; }
  .read-time { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.08em; color: var(--dim); }
  .card-title { font-size: 1.15rem; letter-spacing: -0.01em; line-height: 1.2; }
  .card-desc { font-size: 0.86rem; color: var(--silver); line-height: 1.7; max-width: none; }
  .card-quote { border-left: 2px solid var(--glacier); padding-left: 1rem; font-style: italic; font-size: 0.88rem; color: var(--ice); opacity: 0.75; line-height: 1.65; margin-top: auto; max-width: none; }
  .card-skills { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .skill { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.06em; padding: 0.2rem 0.6rem; border: 1px solid var(--ghost); color: var(--dim); }

  @media (max-width: 960px) { .samples-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 820px) {
    .hero-inner { grid-template-columns: 1fr; }
    .portrait-wrap { width: min(220px, 55vw); margin: 0 auto; }
    .hero-identity { text-align: center; }
    .hero-identity .rule { margin-inline: auto; }
    .hero-bio { margin-inline: auto; }
    .stat-row { justify-content: center; }
    .hero-actions { justify-content: center; }
  }
  @media (max-width: 560px) { .samples-grid { grid-template-columns: 1fr; } }
</style>

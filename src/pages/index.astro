---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.js';
import { samples } from '../data/samples.js';

const featured = samples.filter(s => s.featured);
const { home, stats } = SITE;
---

<BaseLayout title={SITE.siteTitle} description={SITE.description}>

  <section class="home-hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">

      <!-- Left column -->
      <div class="hero-left">
        <div class="portrait-wrap fade-up">
          <img src="/headshot.jpg" alt={SITE.name} class="portrait" />
          <div class="portrait-offset"></div>
        </div>
        <div class="hero-identity fade-up delay-1">
          <p class="eyebrow">{home.eyebrow}</p>
          <h1>{SITE.name}</h1>
          <div class="rule"></div>
          <p class="hero-bio">{home.bio}</p>
          <div class="stat-row">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-num">{s.num}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
          <div class="hero-actions">
            <a href="/work"    class="btn btn-primary">{home.cta_primary}</a>
            <a href="/contact" class="btn btn-outline">{home.cta_secondary}</a>
          </div>
        </div>
      </div>

      <!-- Right column: cards -->
      <div class="hero-right fade-up delay-2">
        <div class="cards-header">
          <p class="eyebrow">{home.featured_heading}</p>
          <a href="/work" class="view-all">{home.featured_link}</a>
        </div>
        <div class="samples-stack">
          {featured.map((sample) => (
            <article class="sample-card">
              <div class="card-top">
                <span class={sample.tagClass}>{sample.category}</span>
                <span class="read-time">{sample.readTime}</span>
              </div>
              <h3 class="card-title">{sample.title}</h3>
              <p class="card-desc">{sample.description}</p>
              <blockquote class="card-quote">{sample.excerpt}</blockquote>
              <div class="card-skills">
                {sample.skills.map((sk) => (
                  <span class="skill">{sk}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .home-hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    padding-block: 2rem clamp(2rem, 4vw, 3rem);
    overflow: hidden;
    min-height: unset;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 65% at 75% 40%, rgba(26,68,89,0.2) 0%, transparent 65%),
      linear-gradient(180deg, var(--void) 0%, var(--obsidian) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .portrait-wrap { position: relative; width: clamp(200px, 22vw, 280px); }
  .portrait { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; position: relative; z-index: 1; }
  .portrait-offset {
    position: absolute; bottom: -8px; right: -8px;
    width: 100%; height: 100%;
    border: 1px solid var(--glacier); opacity: 0.35; z-index: 0;
  }

  .hero-identity { display: flex; flex-direction: column; gap: 0; }
  .hero-identity h1 { font-size: clamp(1.6rem, 2.8vw, 2.8rem); letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 0; }
  .hero-identity .rule { margin-block: 0.85rem; }
  .hero-bio { font-size: 0.92rem; font-weight: 300; color: var(--silver); line-height: 1.8; margin-bottom: 1.25rem; max-width: 44ch; }

  .stat-row { display: flex; gap: 2rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-num { font-family: var(--font-heading); font-size: 1.6rem; font-weight: 400; color: var(--ice); line-height: 1; letter-spacing: -0.02em; }
  .stat-label { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .hero-right { display: flex; flex-direction: column; gap: 0.85rem; }
  .cards-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.1rem; }
  .cards-header .eyebrow { margin-bottom: 0; }
  .view-all { font-size: 0.72rem; font-weight: 500; color: var(--frost); transition: color 0.2s; white-space: nowrap; }
  .view-all:hover { color: var(--ice); }

  .samples-stack { display: flex; flex-direction: column; gap: 0.85rem; }

  .sample-card {
    background: var(--obsidian); border: 1px solid var(--ghost);
    padding: 1.25rem; display: flex; flex-direction: column; gap: 0.55rem;
    transition: border-color 0.25s, transform 0.25s;
  }
  .sample-card:hover { border-color: var(--dim); transform: translateX(3px); }
  .card-top { display: flex; justify-content: space-between; align-items: center; }
  .read-time { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.08em; color: var(--dim); }
  .card-title { font-size: 0.98rem; letter-spacing: -0.01em; line-height: 1.2; }
  .card-desc { font-size: 0.8rem; color: var(--silver); line-height: 1.6; max-width: none; }
  .card-quote { border-left: 2px solid var(--glacier); padding-left: 0.85rem; font-style: italic; font-size: 0.8rem; color: var(--ice); opacity: 0.75; line-height: 1.55; max-width: none; }
  .card-skills { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .skill { font-size: 0.58rem; font-weight: 500; letter-spacing: 0.06em; padding: 0.15rem 0.5rem; border: 1px solid var(--ghost); color: var(--dim); }

  @media (max-width: 900px) {
    .home-hero { min-height: unset; padding-block: 2rem; }
    .hero-inner { grid-template-columns: 1fr; }
    .portrait-wrap { width: min(200px, 50vw); }
    .hero-identity h1 { font-size: clamp(2rem, 6vw, 3rem); }
    .samples-stack { display: grid; grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .samples-stack { grid-template-columns: 1fr; }
  }
</style>

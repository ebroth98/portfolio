---
import { SITE } from '../config.js';

const navLinks = [
  { label: 'Work',         href: '/work'         },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'About',        href: '/about'        },
];

const currentPath = Astro.url.pathname;

function linkClass(href) {
  return currentPath === href ? 'nav-link active' : 'nav-link';
}
---

<header class="site-header" id="siteHeader">
  <div class="container header-inner">

    <a href="/" class="logo" aria-label="Home">
      <img src="/logo.png" alt="Logo" class="logo-img" />
      <div class="logo-text">
        <span class="logo-name">{SITE.name}</span>
        <span class="logo-sub">{SITE.handle}</span>
      </div>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class={linkClass(link.href)}>{link.label}</a>
      ))}
      <a href="/contact" class="btn btn-primary nav-cta">Hire Me</a>
    </nav>

    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="btn btn-primary" style="align-self:flex-start;margin-top:0.5rem">Hire Me</a>
  </div>
</header>

<style>
 .site-header {
    position: sticky; top: 0; z-index: 100;
    overflow: visible;
    background: rgba(8,9,14,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ghost);
    transition: border-color 0.3s;
  }
  .site-header.scrolled { border-bottom-color: var(--dim); }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding-block: 1.1rem;
    gap: 1rem;
  }

  .logo { display: flex; align-items: center; gap: 0.85rem; overflow: visible; }
  .logo-img {
    width: 120px; height: 120px;
    object-fit: contain;
    filter: brightness(1.5) contrast(1.1);
    opacity: 0.65;
    transition: filter 0.2s, opacity 0.2s;
    position: absolute;
    top: -20px;
    left: clamp(1.25rem, 5vw, 3.5rem);
    pointer-events: none;
    z-index: 10;
  }
  }
  .logo:hover .logo-img { filter: brightness(1.8) contrast(1.15); opacity: 1; }
  .logo:hover .logo-name { color: var(--ice); }
  .logo:hover .logo-sub { color: var(--frost); filter: brightness(1.3); }
  .logo-text { display: flex; flex-direction: column; line-height: 1.15; }
  .logo-name { font-family: var(--font-heading); font-size: 1rem; font-weight: 400; color: var(--white); letter-spacing: -0.01em; transition: color 0.2s; }
  .logo-sub  { font-family: var(--font-body); font-size: 0.6rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; color: var(--frost); transition: color 0.2s, filter 0.2s; }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.25rem;
  }
  .nav-link { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.04em; color: var(--silver); transition: color 0.2s; position: relative; padding-bottom: 2px; }
  .nav-link::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px; background: var(--frost); transition: width 0.25s; }
  .nav-link:hover { color: var(--white); }
  .nav-link:hover::after { width: 100%; }
  .nav-link.active { color: var(--ice); }
  .nav-link.active::after { width: 100%; background: var(--ice); }

  .nav-cta { padding: 0.55rem 1.3rem; font-size: 0.72rem; }

  .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; justify-self: end; }
  .hamburger span { display: block; width: 22px; height: 1px; background: var(--silver); transition: transform 0.25s, opacity 0.25s; }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-menu { display: none; flex-direction: column; padding: 1.5rem clamp(1.5rem,5vw,3.5rem); gap: 1.25rem; border-top: 1px solid var(--ghost); background: var(--obsidian); }
  .mobile-link { font-size: 1rem; font-weight: 400; color: var(--silver); transition: color 0.2s; }
  .mobile-link:hover { color: var(--white); }

  @media (max-width: 720px) {
    .header-inner { grid-template-columns: auto auto; }
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .mobile-menu.open { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobileMenu');
  const header = document.getElementById('siteHeader');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.classList.toggle('open');
    btn?.setAttribute('aria-expanded', String(isOpen));
  });
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    menu.classList.remove('open'); btn?.classList.remove('open');
  }));
  window.addEventListener('scroll', () => header?.classList.toggle('scrolled', window.scrollY > 40));
</script>

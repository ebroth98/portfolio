---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.js';

const { testimonials: T } = SITE;

// ── ADD YOUR TESTIMONIALS HERE ─────────────────────────────
// Copy and paste a block below to add more reviews.
const reviews = [
  {
    quote:    "Working with [Your Name] was one of the easiest creative collaborations I've had. They took our messy brief and turned it into copy that actually sounded like us — not like a template.",
    name:     "Client Name",
    title:    "Founder, Company Name",
    category: "Brand & Marketing",
  },
  {
    quote:    "The white paper they wrote for us got more downloads in its first week than anything we'd published before. Dense technical content made genuinely readable.",
    name:     "Client Name",
    title:    "Head of Marketing, Company Name",
    category: "Technical Writing",
  },
  {
    quote:    "I needed someone who could write with warmth and precision at the same time. That's a rare combination and [Your Name] delivered it effortlessly.",
    name:     "Client Name",
    title:    "Brand Director, Company Name",
    category: "Creative Copy",
  },
  {
    quote:    "Add your fourth client review here. Replace this placeholder with a real testimonial when you have one.",
    name:     "Client Name",
    title:    "Title, Company Name",
    category: "Advertising",
  },
];
---

<BaseLayout title={"Testimonials — " + SITE.name} description={T.subhead}>

  <section class="testimonials-section">
    <div class="container">
      <div class="testimonials-grid">
        {reviews.map((r) => (
          <blockquote class="testimonial-card">
            <span class="quote-mark" aria-hidden="true">"</span>
            <p class="quote-text">{r.quote}</p>
            <footer class="quote-footer">
              <div class="quote-attr">
                <span class="quote-name">{r.name}</span>
                <span class="quote-title">{r.title}</span>
              </div>
              <span class="quote-cat tag">{r.category}</span>
            </footer>
          </blockquote>
        ))}
      </div>

      <div class="cta-band">
        <p>
          {T.cta_text}{' '}
          <a href="/contact" class="band-link">{T.cta_link}</a>{' '}
          {T.cta_note}
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .testimonials-section { background: var(--deep); padding-block: clamp(2.5rem, 5vw, 4rem); }
  .testimonials-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-bottom: 3rem; }
  .testimonial-card { background: var(--obsidian); border: 1px solid var(--ghost); padding: 2.25rem; display: flex; flex-direction: column; gap: 1.5rem; transition: border-color 0.25s; }
  .testimonial-card:hover { border-color: var(--dim); }
  .quote-mark { font-family: var(--font-heading); font-size: 4rem; line-height: 0.8; color: var(--arctic); opacity: 0.4; display: block; margin-bottom: -0.5rem; }
  .quote-text { font-family: var(--font-heading); font-style: italic; font-size: clamp(1rem, 1.4vw, 1.15rem); font-weight: 300; color: var(--white); line-height: 1.7; max-width: none; }
  .quote-footer { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: auto; padding-top: 1.25rem; border-top: 1px solid var(--ghost); }
  .quote-attr { display: flex; flex-direction: column; gap: 0.15rem; }
  .quote-name { font-size: 0.88rem; font-weight: 600; color: var(--white); }
  .quote-title { font-size: 0.72rem; color: var(--silver); }
  .cta-band { text-align: center; padding: 2rem; border: 1px solid var(--ghost); background: var(--obsidian); }
  .cta-band p { font-size: 0.95rem; color: var(--silver); max-width: none; margin: 0; }
  .band-link { color: var(--frost); font-weight: 500; transition: color 0.2s; }
  .band-link:hover { color: var(--ice); }
  @media (max-width: 700px) { .testimonials-grid { grid-template-columns: 1fr; } }
</style>
